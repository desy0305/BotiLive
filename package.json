{
  "name": "botilive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit --ignoreDeprecations 6.0 && tsc -p tsconfig.server.json --noEmit --ignoreDeprecations 6.0",
    "lint": "npm run typecheck",
    "preview": "vite preview --host 0.0.0.0 --port 50055",
    "start": "node server/dist/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "@google/genai": "2.7.0",
    "jotai": "^2.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.15"
  }
}
