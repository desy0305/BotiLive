{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "server/src",
    "outDir": "server/dist",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": ["server/src/**/*.ts"]
}
